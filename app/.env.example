APP_NAME=Vitrage Analyzer
APP_HOST=0.0.0.0
APP_PORT=8080
DEBUG=True

POSTGRES_DB=vitrage_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
DATABASE_URL=postgresql+psycopg://postgres:your_password@database:5432/vitrage_db

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=documents

SECRET_KEY=your_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

UPLOAD_DIR=uploads
EXPORT_DIR=exports